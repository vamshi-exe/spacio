# Template for .env — copy to `.env` and fill in real values.
#   cp .env.example .env
# The app shows a setup screen (instead of crashing) until these are filled in.

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ── Supabase (Project Settings → API) ───────────────────────────────────────
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── Cloudinary (Dashboard → Cloud name / unsigned upload preset) ────────────
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_UPLOAD_PRESET=YOUR_CLOUDINARY_UPLOAD_PRESET

# ── Razorpay (Dashboard → Settings → API Keys) ──────────────────────────────
# Only the publishable key id belongs in the app. The KEY SECRET must never be
# put in this file — it ships inside the app bundle. Store it server-side as a
# Supabase Edge Function secret:
#   supabase secrets set RAZORPAY_KEY_SECRET=...
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
